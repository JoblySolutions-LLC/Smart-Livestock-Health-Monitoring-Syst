private static final int MAX_RETRIES    = 5;
private static final int RETRY_DELAY_MS = 3000;

@PostConstruct
public void connect() {
    int attempt = 0;
    while (attempt < MAX_RETRIES) {
        try {
            mqttClient.connect(options);
            log.info("MQTT connected on attempt {}", attempt + 1);
            return;
        } catch (MqttException e) {
            attempt++;
            log.warn("MQTT connect failed (attempt {}): {}", attempt, e.getMessage());
            if (attempt < MAX_RETRIES) Thread.sleep(RETRY_DELAY_MS);
        }
    }
    throw new RuntimeException("MQTT broker unreachable after " + MAX_RETRIES + " attempts");
}
